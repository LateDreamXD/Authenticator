{
  "name": "latedream-auth",
  "version": "1.0.0-dev.1",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "build": "run-p web:build app:build",
    "dev": "run-p web:dev start",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "app:build": "cross-env NODE_ENV=production electron-builder"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vueuse/core": "^14.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ini-es": "^0.3.0",
    "lucide-vue-next": "^0.563.0",
    "npm-run-all-next": "^1.1.2",
    "otpauth": "^9.5.0",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.8.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^5.0.1",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify/vue": "^5.0.0",
    "@latedream/niva-types": "^0.9.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.11",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "electron": "34.5.8",
    "electron-builder": "^26.7.0",
    "jiti": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^31.0.0",
    "vite": "beta",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "asar": true,
    "compression": "maximum",
    "appId": "cn.latedream.auth",
    "productName": "LateDream Authenticator",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist",
      "electron"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
