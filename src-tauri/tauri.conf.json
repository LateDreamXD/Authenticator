{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "latedream-auth",
  "version": "../package.json",
  "identifier": "cn.latedream.authenticator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm cross-env CLIENT=true pnpm dev",
    "beforeBuildCommand": "pnpm cross-env CLIENT=true pnpm pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "LateDream Authenticator",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; img-src 'self' data: file:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage", "deb", "dmg", "msi"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "nsis": null,
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "wix": null
    },
    "category": "Utility",
    "copyright": "Copyright (c) 2026 LateDreamXD"
  }
}
